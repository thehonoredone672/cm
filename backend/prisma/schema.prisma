generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ADMIN
  FACULTY
  MENTOR
  RECRUITER
}

enum EducationType {
  SCHOOL
  COLLEGE
  EMPLOYED
  SELF_LEARNER
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(STUDENT)

  bio          String?
  profileImage String?
  githubUrl    String?
  linkedinUrl  String?

  educationType EducationType?

  schoolName String?
  standard   Int?

  college      String?
  department   String?
  academicYear Int?

  company    String?
  position   String?
  profession String?

  skills    UserSkill[]
  interests UserInterest[]

  teamRequests TeamRequest[]
  applications Application[]

  messages Message[]

  conversations ConversationParticipant[]

  sentInvites     TeamInvite[] @relation("InviteSender")
  receivedInvites TeamInvite[] @relation("InviteReceiver")

  teamsLed        Team[]         @relation("TeamLeader")
  teamMemberships TeamMember[]
  submissions     Submission[]
  notifications   Notification[]
  projects        Project[]

  isBlocked       Boolean              @default(false)
  streak          Int                  @default(0)
  githubId        String?
  leetcodeProfile String?
  filedReports    Report[]             @relation("ReporterRelation")
  badges          UserBadge[]
  posts           CommunityPost[]
  postLikes       PostLike[]
  comments        PostComment[]
  bookmarked      BookmarkedResource[]
  jobApplications JobApplication[]

  collegeId          String?
  collegeRelation    College?               @relation(fields: [collegeId], references: [id])
  facultyProfile     FacultyProfile?
  mentorProfile      MentorProfile?
  companyProfile     CompanyProfile?
  eventRegistrations EventRegistration[]
  mentorshipBookings MentorshipBooking[]
  driveApplications  CandidateApplication[]
  certificates       Certificate[]

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  teamAnnouncements    TeamAnnouncement[]
  teamTasks            TeamTask[]
  teamFiles            TeamFile[]
  teamActivities       TeamActivity[]
  messageReactions     MessageReaction[]
  problemBookmarks     ProblemBookmark[]
  problemLikes         ProblemLike[]
  problemDiscussions   ProblemDiscussion[]
  problemReports       ProblemReport[]
  codeDrafts           CodeDraft[]
  languagePreference   LanguagePreference?
  editorSettings       EditorSettings?
  contestRegistrations ContestRegistration[]
}

model Skill {
  id   String @id @default(uuid())
  name String @unique

  users UserSkill[]
}

model UserSkill {
  id String @id @default(uuid())

  userId  String
  skillId String

  user  User  @relation(fields: [userId], references: [id])
  skill Skill @relation(fields: [skillId], references: [id])

  proficiency       String   @default("INTERMEDIATE") // BEGINNER, INTERMEDIATE, ADVANCED, EXPERT
  yearsOfExperience Int      @default(0)
  createdAt         DateTime @default(now())

  @@unique([userId, skillId])
}

model Interest {
  id       String @id @default(uuid())
  name     String @unique
  category String @default("Programming")

  users UserInterest[]
}

model UserInterest {
  id String @id @default(uuid())

  userId     String
  interestId String

  user     User     @relation(fields: [userId], references: [id])
  interest Interest @relation(fields: [interestId], references: [id])

  matchingWeight Int      @default(1)
  createdAt      DateTime @default(now())

  @@unique([userId, interestId])
}

model TeamRequest {
  id String @id @default(uuid())

  creatorId String

  title       String
  description String
  duration    String

  status String @default("OPEN")

  creator User @relation(fields: [creatorId], references: [id])

  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Application {
  id String @id @default(uuid())

  teamRequestId String
  applicantId   String

  status ApplicationStatus @default(PENDING)

  teamRequest TeamRequest @relation(fields: [teamRequestId], references: [id])
  applicant   User        @relation(fields: [applicantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id     String  @id @default(uuid())
  teamId String? @unique
  name   String?

  participants ConversationParticipant[]
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConversationParticipant {
  id String @id @default(uuid())

  conversationId String
  userId         String

  lastReadAt DateTime?
  isPinned   Boolean   @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}

model Message {
  id String @id @default(uuid())

  conversationId String
  senderId       String

  text         String
  isDeleted    Boolean           @default(false)
  fileUrl      String?
  fileType     String? // IMAGE or FILE
  isPinned     Boolean           @default(false)
  isEdited     Boolean           @default(false)
  codeLanguage String?
  reactions    MessageReaction[]

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  createdAt DateTime @default(now())
}

model TeamInvite {
  id String @id @default(uuid())

  senderId   String
  receiverId String

  message String?

  status InviteStatus @default(PENDING)

  sender   User @relation("InviteSender", fields: [senderId], references: [id])
  receiver User @relation("InviteReceiver", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model Team {
  id          String       @id @default(uuid())
  name        String
  description String?
  joinCode    String       @unique
  leaderId    String
  leader      User         @relation("TeamLeader", fields: [leaderId], references: [id])
  members     TeamMember[]

  isRecruiting      Boolean  @default(true)
  maxMembers        Int      @default(5)
  requiredSkills    String[]
  requiredInterests String[]

  announcements TeamAnnouncement[]
  tasks         TeamTask[]
  files         TeamFile[]
  activities    TeamActivity[]
  resources     TeamResource[]

  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  hackathonRegistrations HackathonRegistration[]
}

model TeamMember {
  id       String   @id @default(uuid())
  teamId   String
  userId   String
  role     String   @default("MEMBER") // LEADER, ADMIN, MEMBER
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([teamId, userId])
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Problem {
  id              String              @id @default(uuid())
  title           String
  description     String
  category        String
  difficulty      Difficulty          @default(EASY)
  tags            String[]
  companies       String[]
  constraints     String?
  status          String              @default("PUBLISHED") // DRAFT, PUBLISHED
  visibility      String              @default("PUBLIC") // PUBLIC, PRIVATE
  starterCode     Json // E.g. { python: "...", javascript: "...", cpp: "...", java: "...", c: "..." }
  examples        Json // E.g. [{ input: "...", output: "...", explanation: "..." }]
  testCases       TestCase[]
  submissions     Submission[]
  bookmarks       ProblemBookmark[]
  likes           ProblemLike[]
  discussions     ProblemDiscussion[]
  editorial       ProblemEditorial?
  reports         ProblemReport[]
  solutions       Solution[]
  contestProblems ContestProblem[]
  dailyChallenge  DailyChallenge?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model TestCase {
  id             String   @id @default(uuid())
  problemId      String
  problem        Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  input          String
  expectedOutput String
  isPublic       Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model Submission {
  id              String   @id @default(uuid())
  problemId       String
  userId          String
  code            String
  language        String
  status          String
  errorMessage    String?
  executionTime   Float?
  memoryUsage     Int?
  testCasesPassed Int      @default(0)
  totalTestCases  Int      @default(0)
  problem         Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String
  githubUrl   String?
  liveDemoUrl String?
  techStack   String[]
  images      String[]
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Report {
  id         String   @id @default(uuid())
  reporterId String
  reporter   User     @relation("ReporterRelation", fields: [reporterId], references: [id], onDelete: Cascade)
  targetType String // USER, TEAM, MESSAGE
  targetId   String
  reason     String
  status     String   @default("PENDING") // PENDING, RESOLVED, DISMISSED
  createdAt  DateTime @default(now())
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SystemConfig {
  key   String @id
  value String
}

model Hackathon {
  id            String                  @id @default(uuid())
  title         String
  description   String
  date          DateTime
  link          String
  createdAt     DateTime                @default(now())
  registrations HackathonRegistration[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeName String
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeName])
}

model CommunityPost {
  id        String        @id @default(uuid())
  authorId  String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title     String
  content   String
  tags      String[]
  likes     PostLike[]
  comments  PostComment[]
  createdAt DateTime      @default(now())
}

model PostLike {
  id     String        @id @default(uuid())
  postId String
  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model PostComment {
  id        String        @id @default(uuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime      @default(now())
}

model LearningResource {
  id           String               @id @default(uuid())
  title        String
  description  String
  category     String // Roadmaps, Tutorials, Articles
  link         String
  createdAt    DateTime             @default(now())
  bookmarkedBy BookmarkedResource[]
}

model BookmarkedResource {
  id         String           @id @default(uuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceId String
  resource   LearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
}

model JobListing {
  id          String           @id @default(uuid())
  title       String
  company     String
  description String
  location    String
  type        String // Internship, Job
  link        String
  createdAt   DateTime         @default(now())
  appliedJobs JobApplication[]
}

model JobApplication {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       JobListing @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status    String     @default("PENDING") // PENDING, SAVED, APPLIED, INTERVIEWING, REJECTED
  createdAt DateTime   @default(now())

  @@unique([userId, jobId])
}

model DailyChallenge {
  id        String   @id @default(uuid())
  problemId String   @unique
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  date      DateTime @unique
}

model College {
  id        String             @id @default(uuid())
  name      String             @unique
  domain    String?
  createdAt DateTime           @default(now())
  users     User[]
  drives    RecruitmentDrive[]
}

model FacultyProfile {
  id         String  @id @default(uuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  department String
  title      String
  verified   Boolean @default(false)
}

model HackathonRegistration {
  id           String    @id @default(uuid())
  hackathonId  String
  hackathon    Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  teamId       String
  team         Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  projectTitle String?
  projectDesc  String?
  projectLink  String?
  score        Float?
  isWinner     Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@unique([hackathonId, teamId])
}

model Event {
  id            String              @id @default(uuid())
  title         String
  description   String
  type          String // WORKSHOP, WEBINAR, TECH_EVENT
  date          DateTime
  link          String?
  speaker       String?
  createdAt     DateTime            @default(now())
  registrations EventRegistration[]
}

model EventRegistration {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  attended  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

model MentorProfile {
  id       String              @id @default(uuid())
  userId   String              @unique
  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  title    String
  company  String
  bio      String
  skills   String[]
  rating   Float               @default(5.0)
  bookings MentorshipBooking[]
}

model MentorshipBooking {
  id              String        @id @default(uuid())
  mentorProfileId String
  mentor          MentorProfile @relation(fields: [mentorProfileId], references: [id], onDelete: Cascade)
  studentId       String
  student         User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scheduledAt     DateTime
  status          String        @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  rating          Int?
  feedback        String?
  createdAt       DateTime      @default(now())
}

model CompanyProfile {
  id          String             @id @default(uuid())
  name        String             @unique
  description String
  website     String
  logoUrl     String?
  userId      String             @unique
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  drives      RecruitmentDrive[]
}

model RecruitmentDrive {
  id         String                 @id @default(uuid())
  companyId  String
  company    CompanyProfile         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  collegeId  String?
  college    College?               @relation(fields: [collegeId], references: [id])
  title      String
  status     String                 @default("UPCOMING") // UPCOMING, ACTIVE, COMPLETED
  date       DateTime
  createdAt  DateTime               @default(now())
  candidates CandidateApplication[]
}

model CandidateApplication {
  id             String           @id @default(uuid())
  driveId        String
  drive          RecruitmentDrive @relation(fields: [driveId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         String           @default("APPLIED") // APPLIED, SCREENED, ASSESSMENT_PENDING, INTERVIEWING, OFFERED, REJECTED
  score          Int?
  offerLetterUrl String?
  createdAt      DateTime         @default(now())

  @@unique([driveId, userId])
}

model Certificate {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  issuedBy         String
  verificationCode String   @unique
  qrCodeUrl        String?
  createdAt        DateTime @default(now())
}

model TeamAnnouncement {
  id        String   @id @default(uuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  title     String
  content   String
  isPinned  Boolean  @default(false)
  creatorId String
  creator   User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model TeamTask {
  id          String    @id @default(uuid())
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String    @default("TODO") // TODO, IN_PROGRESS, COMPLETED
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH
  dueDate     DateTime?
  assigneeId  String?
  assignee    User?     @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
}

model TeamFile {
  id           String   @id @default(uuid())
  teamId       String
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name         String
  fileUrl      String
  fileSize     Int
  fileType     String
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model TeamActivity {
  id        String   @id @default(uuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String
  createdAt DateTime @default(now())
}

model TeamResource {
  id        String   @id @default(uuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  title     String
  url       String
  createdAt DateTime @default(now())
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
}

model ProblemBookmark {
  id        String   @id @default(uuid())
  problemId String
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([problemId, userId])
}

model ProblemLike {
  id        String   @id @default(uuid())
  problemId String
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isLike    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([problemId, userId])
}

model ProblemDiscussion {
  id        String   @id @default(uuid())
  problemId String
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  isPinned  Boolean  @default(false)
  isTop     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProblemEditorial {
  id        String   @id @default(uuid())
  problemId String   @unique
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  content   String
  isLocked  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProblemReport {
  id        String   @id @default(uuid())
  problemId String
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  createdAt DateTime @default(now())
}

model CodeDraft {
  id        String   @id @default(uuid())
  problemId String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language  String
  code      String
  updatedAt DateTime @updatedAt

  @@unique([problemId, userId, language])
}

model LanguagePreference {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EditorSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme     String   @default("vs-dark")
  fontSize  Int      @default(14)
  wordWrap  String   @default("off")
  minimap   Boolean  @default(false)
  autoSave  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Solution {
  id            String               @id @default(uuid())
  problemId     String
  problem       Problem              @relation(fields: [problemId], references: [id], onDelete: Cascade)
  title         String
  language      String
  visibility    String               @default("PRIVATE") // PUBLIC, PRIVATE
  approachId    String?              @unique
  approach      SolutionApproach?    @relation(fields: [approachId], references: [id], onDelete: Cascade)
  explanationId String?              @unique
  explanation   SolutionExplanation? @relation(fields: [explanationId], references: [id], onDelete: Cascade)
  complexityId  String?              @unique
  complexity    SolutionComplexity?  @relation(fields: [complexityId], references: [id], onDelete: Cascade)
  code          String
  createdBy     String
  updatedBy     String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model SolutionApproach {
  id          String    @id @default(uuid())
  title       String
  description String
  solution    Solution?
}

model SolutionExplanation {
  id       String    @id @default(uuid())
  steps    String
  solution Solution?
}

model SolutionComplexity {
  id       String    @id @default(uuid())
  time     String
  space    String
  solution Solution?
}

model Contest {
  id            String                @id @default(uuid())
  title         String
  description   String
  startTime     DateTime
  endTime       DateTime
  type          String                @default("PUBLIC") // PRACTICE, PUBLIC, PRIVATE, COLLEGE, HACKATHON, RECRUITMENT
  status        String                @default("UPCOMING") // UPCOMING, ACTIVE, COMPLETED
  problems      ContestProblem[]
  registrations ContestRegistration[]
  announcements ContestAnnouncement[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model ContestProblem {
  id        String  @id @default(uuid())
  contestId String
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  points    Int     @default(100)
  order     Int     @default(0)

  @@unique([contestId, problemId])
}

model ContestRegistration {
  id        String   @id @default(uuid())
  contestId String
  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([contestId, userId])
}

model ContestAnnouncement {
  id        String   @id @default(uuid())
  contestId String
  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  title     String
  content   String
  createdAt DateTime @default(now())
}
